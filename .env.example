# Required — LLM (Ollama cloud)
OLLAMA_API_KEY=
LLM_BASE_URL=https://ollama.com/v1
LLM_MODEL=ministral-3:8b

# Optional — Web Search (free: sign up at https://tavily.com)
# Without this, falls back to Wikipedia + DuckDuckGo (which may CAPTCHA)
TAVILY_API_KEY=

# Required for Deep Mode — x402 Payments (Injective)
# Address that receives USDC payments
NEXT_PUBLIC_PREMIUM_RECIPIENT_ADDRESS=
# Private key of a wallet funded with INJ for gas (settlement tx)
X402_PRIVATE_KEY=

# Injective RPC
INJECTIVE_RPC_URL=https://injective-rpc.publicnode.com
INJECTIVE_REST_URL=https://injective-api.publicnode.com
NEXT_PUBLIC_INJECTIVE_REST_URL=https://injective-api.publicnode.com
INJECTIVE_NETWORK=testnet

# Database (MongoDB Atlas — for chat history / subscriptions)
MONGODB_URI=

# Auth (Clerk — for chat history persistence)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
